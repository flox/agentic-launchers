#!/usr/bin/env bash
set -euo pipefail

case "${BASH_SOURCE[0]}" in
  */*) LAUNCHER_SCRIPT_DIR="${BASH_SOURCE[0]%/*}" ;;
  *) LAUNCHER_SCRIPT_DIR="." ;;
esac
LAUNCHER_SCRIPT_DIR="$(cd -- "$LAUNCHER_SCRIPT_DIR" && pwd -P)" || exit 1

# Wrapper for codex to use ollama directly (OpenAI-compat endpoint).
# Data is isolated to $FLOX_ENV_CACHE/codex via CODEX_HOME so ~/.codex
# is never touched.
#
# Usage: launch-codex --model <model> [codex args...]
#   e.g. launch-codex --model qwen2.5-coder
#        launch-codex --model qwen2.5-coder -q "explain this codebase"

MODEL=""
CODEX_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model|-m)
      if [[ $# -lt 2 || -z "${2:-}" || "${2:-}" == -* ]]; then
        echo "Error: $1 requires a model value" >&2
        exit 2
      fi
      MODEL="$2"
      shift 2
      ;;
    --model=*)
      MODEL="${1#--model=}"
      if [[ -z "$MODEL" ]]; then
        echo "Error: --model requires a non-empty value" >&2
        exit 2
      fi
      shift
      ;;
    *)
      CODEX_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: launch-codex --model <model> [codex args...]" >&2
  exit 1
fi

source "$LAUNCHER_SCRIPT_DIR/_ollama-ensure.sh"
ollama_normalize_base_url
ollama_ensure_model "$MODEL" "$OLLAMA_BASE_URL" || exit 1

export CODEX_HOME="${FLOX_ENV_CACHE}/codex"
mkdir -p "$CODEX_HOME"

source "$LAUNCHER_SCRIPT_DIR/_launcher-common.sh"
printf '%s' '{"auth_mode":"apikey","OPENAI_API_KEY":"ollama"}' \
  | launcher_write_file_if_absent "$CODEX_HOME/auth.json" 600

exec codex \
  -c 'model_provider="ollama"' \
  -c "model=\"${MODEL}\"" \
  ${CODEX_ARGS[@]+"${CODEX_ARGS[@]}"}
