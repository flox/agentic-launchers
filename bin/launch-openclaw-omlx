#!/usr/bin/env bash
set -euo pipefail

case "${BASH_SOURCE[0]}" in
  */*) LAUNCHER_SCRIPT_DIR="${BASH_SOURCE[0]%/*}" ;;
  *) LAUNCHER_SCRIPT_DIR="." ;;
esac
LAUNCHER_SCRIPT_DIR="$(cd -- "$LAUNCHER_SCRIPT_DIR" && pwd -P)" || exit 1

# Wrapper for openclaw to use omlx via the OpenAI completions API.
# omlx natively serves /v1/chat/completions, so no proxy is needed.
# Config is injected into the 'omlx' openclaw profile (~/.openclaw-omlx/)
# via 'openclaw config patch' to avoid touching the user's default profile.
#
# Usage: launch-openclaw-omlx --model <hf-model-id> [openclaw args...]
#   e.g. launch-openclaw-omlx --model mlx-community/Qwen2.5-Coder-1.5B-Instruct-4bit

MODEL=""
OPENCLAW_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model|-m)
      if [[ $# -lt 2 || -z "${2:-}" || "${2:-}" == -* ]]; then
        echo "Error: $1 requires a model value" >&2
        exit 2
      fi
      MODEL="$2"
      shift 2
      ;;
    --model=*)
      MODEL="${1#--model=}"
      if [[ -z "$MODEL" ]]; then
        echo "Error: --model requires a non-empty value" >&2
        exit 2
      fi
      shift
      ;;
    *)
      OPENCLAW_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: omlx launch openclaw --model <hf-model-id> [openclaw args...]" >&2
  exit 1
fi

OMLX_HOST="${OMLX_HOST:-127.0.0.1}"
OMLX_PORT="${OMLX_PORT:-8000}"

source "$LAUNCHER_SCRIPT_DIR/_omlx-ensure.sh"
OMLX_BASE_URL="$(_omlx_base_url "$OMLX_HOST" "$OMLX_PORT")" || exit 1
omlx_ensure_model "$MODEL" "$OMLX_HOST" "$OMLX_PORT" || exit 1

source "$LAUNCHER_SCRIPT_DIR/_launcher-common.sh"
PROFILE_KEY="$(launcher_profile_key "openclaw-omlx" "$MODEL" "$OMLX_MODEL_ID" "$OMLX_BASE_URL" "$OMLX_API_KEY" "openai-completions")" || {
  echo "Error: could not derive openclaw profile key" >&2
  exit 1
}
OPENCLAW_PROFILE="omlx-${PROFILE_KEY}"

# OMLX_MODEL_ID is the provenance-verified server-visible catalog identity.
_config_json="$(jq -n \
  --arg base "${OMLX_BASE_URL}/v1" \
  --arg key "$OMLX_API_KEY" \
  --arg model "$OMLX_MODEL_ID" \
  '{
    models: {
      mode: "replace",
      providers: {
        omlx: {
          api: "openai-completions",
          baseUrl: $base,
          auth: "api-key",
          apiKey: $key,
          models: [{id:$model,name:$model}]
        }
      }
    },
    agents: {defaults: {model:("omlx/" + $model)}}
  }')"
printf '%s\n' "$_config_json" | openclaw --profile "$OPENCLAW_PROFILE" config patch --stdin

exec openclaw --profile "$OPENCLAW_PROFILE" chat ${OPENCLAW_ARGS[@]+"${OPENCLAW_ARGS[@]}"}
