#!/usr/bin/env bash
set -euo pipefail

# Wrapper for openclaw to use ollama via the OpenAI completions API.
# Config is injected into the 'ollama' openclaw profile (~/.openclaw-ollama/)
# to avoid touching the user's default profile.
#
# Usage: launch-openclaw --model <model> [openclaw args...]
#   e.g. launch-openclaw --model qwen2.5-coder

MODEL=""
OPENCLAW_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)
      MODEL="${2:?--model requires a value}"
      shift 2
      ;;
    *)
      OPENCLAW_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: launch-openclaw --model <model> [openclaw args...]" >&2
  exit 1
fi

source "${BASH_SOURCE[0]%/*}/_ollama-ensure.sh"
ollama_normalize_host_port
ollama_ensure_model "$MODEL" "$OLLAMA_HOST" "$OLLAMA_PORT" || exit 1

MODEL_JSON="${MODEL//\\/\\\\}"
MODEL_JSON="${MODEL_JSON//\"/\\\"}"

openclaw --profile ollama config patch --stdin <<EOF
{
  "models": {
    "mode": "replace",
    "providers": {
      "ollama": {
        "api": "openai-completions",
        "baseUrl": "http://${OLLAMA_HOST}:${OLLAMA_PORT}/v1",
        "auth": "api-key",
        "apiKey": "ollama",
        "models": [
          {
            "id": "${MODEL_JSON}",
            "name": "${MODEL_JSON}"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "ollama/${MODEL_JSON}"
    }
  }
}
EOF

exec openclaw --profile ollama chat ${OPENCLAW_ARGS[@]+"${OPENCLAW_ARGS[@]}"}
