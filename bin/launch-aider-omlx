#!/usr/bin/env bash
set -euo pipefail

case "${BASH_SOURCE[0]}" in
  */*) LAUNCHER_SCRIPT_DIR="${BASH_SOURCE[0]%/*}" ;;
  *) LAUNCHER_SCRIPT_DIR="." ;;
esac
LAUNCHER_SCRIPT_DIR="$(cd -- "$LAUNCHER_SCRIPT_DIR" && pwd -P)" || exit 1

# Wrapper for aider to use omlx.
# aider uses OPENAI_API_BASE for custom OpenAI-compat endpoints; no proxy needed.
#
# Usage: launch-aider-omlx --model <hf-model-id> [aider args...]
#   e.g. launch-aider-omlx --model mlx-community/Qwen3.5-9B-MLX-4bit

MODEL=""
AIDER_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model|-m)
      if [[ $# -lt 2 || -z "${2:-}" || "${2:-}" == -* ]]; then
        echo "Error: $1 requires a model value" >&2
        exit 2
      fi
      MODEL="$2"
      shift 2
      ;;
    --model=*)
      MODEL="${1#--model=}"
      if [[ -z "$MODEL" ]]; then
        echo "Error: --model requires a non-empty value" >&2
        exit 2
      fi
      shift
      ;;
    *)
      AIDER_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: omlx launch aider --model <hf-model-id> [aider args...]" >&2
  exit 1
fi

OMLX_HOST="${OMLX_HOST:-127.0.0.1}"
OMLX_PORT="${OMLX_PORT:-8000}"

source "$LAUNCHER_SCRIPT_DIR/_omlx-ensure.sh"
OMLX_BASE_URL="$(_omlx_base_url "$OMLX_HOST" "$OMLX_PORT")" || exit 1
omlx_ensure_model "$MODEL" "$OMLX_HOST" "$OMLX_PORT" || exit 1

export OPENAI_API_BASE="${OMLX_BASE_URL}/v1"
export OPENAI_API_KEY="$OMLX_API_KEY"

exec aider \
  --model "openai/${OMLX_MODEL_ID}" \
  ${AIDER_ARGS[@]+"${AIDER_ARGS[@]}"}
