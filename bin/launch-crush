#!/usr/bin/env bash
set -euo pipefail

# Wrapper for crush to use ollama via the llamacpp-proxy-ollama service.
# crush speaks openai-compat; the persistent proxy translates to ollama.
# Config is isolated to $FLOX_ENV_CACHE to avoid overwriting ~/.config/crush.
#
# Note: if launch-gemini switches models while crush is running, the proxy
# service restarts and the active crush session will be interrupted.
#
# Usage: launch-crush --model <model> [crush args...]
#   e.g. launch-crush --model qwen2.5
#        launch-crush --model qwen2.5 --yolo

MODEL=""
CRUSH_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)
      MODEL="${2:?--model requires a value}"
      shift 2
      ;;
    *)
      CRUSH_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: launch-crush --model <model> [crush args...]" >&2
  exit 1
fi

OLLAMA_HOST="${OLLAMA_HOST:-127.0.0.1}"
OLLAMA_PORT="${OLLAMA_PORT:-11434}"

source "${BASH_SOURCE[0]%/*}/_ollama-ensure.sh"
ollama_ensure_model "$MODEL" "$OLLAMA_HOST" "$OLLAMA_PORT" || exit 1

PROXY_LISTEN="${LLAMACPP_PROXY_OLLAMA_LISTEN:-127.0.0.1:8081}"
if ! curl -sf --connect-timeout 1 --max-time 2 "http://${PROXY_LISTEN}/health" >/dev/null 2>&1; then
  echo "Error: llamacpp-proxy-ollama service is not running." >&2
  echo "  Start with: flox activate -s  (or: flox services start llamacpp-proxy-ollama)" >&2
  exit 1
fi

CRUSH_DATA_DIR="${FLOX_ENV_CACHE}/crush"
mkdir -p "$CRUSH_DATA_DIR"

MODEL_JSON="${MODEL//\\/\\\\}"
MODEL_JSON="${MODEL_JSON//\"/\\\"}"

cat > "$CRUSH_DATA_DIR/crush.json" <<EOF
{
  "providers": {
    "llamacpp": {
      "type": "openai-compat",
      "base_url": "http://${PROXY_LISTEN}/v1",
      "api_key": "llamacpp-local",
      "models": [
        {
          "id": "${MODEL_JSON}",
          "name": "${MODEL_JSON}",
          "context_window": 65536
        }
      ]
    }
  },
  "models": {
    "large": {
      "model": "${MODEL_JSON}",
      "provider": "llamacpp",
      "max_tokens": 8192
    },
    "small": {
      "model": "${MODEL_JSON}",
      "provider": "llamacpp",
      "max_tokens": 4096
    }
  }
}
EOF

exec crush -D "$CRUSH_DATA_DIR" ${CRUSH_ARGS[@]+"${CRUSH_ARGS[@]}"}
