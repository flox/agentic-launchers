#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="${BASH_SOURCE[0]%/*}"

# Find the real ollama binary, skipping this wrapper.
_real_ollama() {
  local self_dir
  self_dir="$(cd "$SCRIPT_DIR" && pwd)"
  IFS=: read -ra _path_dirs <<< "$PATH"
  for dir in "${_path_dirs[@]}"; do
    if [[ -x "$dir/ollama" ]] && [[ "$(cd "$dir" && pwd)" != "$self_dir" ]]; then
      echo "$dir/ollama"
      return 0
    fi
  done
  echo "Error: cannot find ollama binary" >&2
  return 1
}

# Dispatch resolver commands before checking for launch
case "${1:-}" in
  search)       shift 1; exec ollama-model-resolver search "$@" ;;
  resolve)      shift 1; exec ollama-model-resolver resolve "$@" ;;
  resolver-info) shift 1; exec ollama-model-resolver info "$@" ;;
esac

# Pass through if not "ollama launch ..."
if [[ "${1:-}" != "launch" ]]; then
  exec "$(_real_ollama)" "$@"
fi

TOOL="${2:-}"

# For launch subcommands, resolve any --model value ending in ?
shift 2
RESOLVED_ARGS=()
_resolve_next=false
for arg in "$@"; do
  if $_resolve_next; then
    _resolve_next=false
    if [[ "$arg" == *'?' ]]; then
      arg="$(ollama-model-resolver resolve "$arg" --quiet)" || exit 1
    fi
    RESOLVED_ARGS+=("$arg")
  elif [[ "$arg" == "--model" || "$arg" == "-m" ]]; then
    RESOLVED_ARGS+=("$arg")
    _resolve_next=true
  elif [[ "$arg" == --model=* ]]; then
    _val="${arg#--model=}"
    if [[ "$_val" == *'?' ]]; then
      _val="$(ollama-model-resolver resolve "$_val" --quiet)" || exit 1
    fi
    RESOLVED_ARGS+=("--model" "$_val")
  else
    RESOLVED_ARGS+=("$arg")
  fi
done

# Dispatch to launch wrappers with resolved args
case "$TOOL" in
  gemini)              exec "$SCRIPT_DIR/launch-gemini" ${RESOLVED_ARGS[@]+"${RESOLVED_ARGS[@]}"} ;;
  codex)               exec "$SCRIPT_DIR/launch-codex" ${RESOLVED_ARGS[@]+"${RESOLVED_ARGS[@]}"} ;;
  crush)               exec "$SCRIPT_DIR/launch-crush" ${RESOLVED_ARGS[@]+"${RESOLVED_ARGS[@]}"} ;;
  deepseek)            exec "$SCRIPT_DIR/launch-deepseek" ${RESOLVED_ARGS[@]+"${RESOLVED_ARGS[@]}"} ;;
  aider)               exec "$SCRIPT_DIR/launch-aider" ${RESOLVED_ARGS[@]+"${RESOLVED_ARGS[@]}"} ;;
  nanocoder)           exec "$SCRIPT_DIR/launch-nanocoder" ${RESOLVED_ARGS[@]+"${RESOLVED_ARGS[@]}"} ;;
  *)         exec "$(_real_ollama)" launch "$TOOL" ${RESOLVED_ARGS[@]+"${RESOLVED_ARGS[@]}"} ;;
esac
