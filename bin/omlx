#!/usr/bin/env bash
set -euo pipefail

case "${BASH_SOURCE[0]}" in
  */*) _script_parent="${BASH_SOURCE[0]%/*}" ;;
  *)   _script_parent="." ;;
esac
SCRIPT_DIR="$(cd -- "$_script_parent" && pwd -P)"
unset _script_parent

# Find the real omlx binary, skipping this wrapper and any symlink to it.
_real_omlx() {
  local remaining="${PATH:-}:" dir candidate
  while [[ "$remaining" == *:* ]]; do
    dir="${remaining%%:*}"
    remaining="${remaining#*:}"
    [[ -n "$dir" ]] || dir="."
    candidate="${dir%/}/omlx"
    if [[ -x "$candidate" && ! -d "$candidate" && ! "$candidate" -ef "${BASH_SOURCE[0]}" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  echo "Error: cannot find omlx binary" >&2
  return 1
}

_exec_real_omlx() {
  local real
  real="$(_real_omlx)" || return $?
  exec "$real" "$@"
}

# Pass through if not "omlx launch ...".
if [[ "${1:-}" != "launch" ]]; then
  _exec_real_omlx "$@"
fi

TOOL="${2:-}"

# Dispatch known tools to our wrappers; everything else passes through to
# the real omlx binary (including a bare launch and native tools such as pi).
case "$TOOL" in
  gemini)               shift 2; exec "$SCRIPT_DIR/launch-gemini-omlx" "$@" ;;
  deepseek)             shift 2; exec "$SCRIPT_DIR/launch-deepseek-omlx" "$@" ;;
  aider)                shift 2; exec "$SCRIPT_DIR/launch-aider-omlx" "$@" ;;
  claude|claude-code)   shift 2; exec "$SCRIPT_DIR/launch-claude-omlx" "$@" ;;
  hermes|hermes-agent)  shift 2; exec "$SCRIPT_DIR/launch-hermes-omlx" "$@" ;;
  crush)                shift 2; exec "$SCRIPT_DIR/launch-crush-omlx" "$@" ;;
  opencode)             shift 2; exec "$SCRIPT_DIR/launch-opencode-omlx" "$@" ;;
  codex)                shift 2; exec "$SCRIPT_DIR/launch-codex-omlx" "$@" ;;
  openclaw)             shift 2; exec "$SCRIPT_DIR/launch-openclaw-omlx" "$@" ;;
  nanocoder)            shift 2; exec "$SCRIPT_DIR/launch-nanocoder-omlx" "$@" ;;
  *)                    _exec_real_omlx "$@" ;;
esac
