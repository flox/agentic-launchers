#!/usr/bin/env bash
set -euo pipefail

# Wrapper for claude-code to use ollama via llamacpp-proxy.
# llamacpp-proxy translates Anthropic Messages API ↔ OpenAI ↔ ollama.
#
# Usage: launch-claude --model <model> [claude args...]
#   e.g. launch-claude --model qwen2.5-coder

MODEL=""
CLAUDE_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)
      MODEL="${2:?--model requires a value}"
      shift 2
      ;;
    *)
      CLAUDE_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: launch-claude --model <model> [claude args...]" >&2
  exit 1
fi

source "${BASH_SOURCE[0]%/*}/_ollama-ensure.sh"
ollama_normalize_host_port
ollama_ensure_model "$MODEL" "$OLLAMA_HOST" "$OLLAMA_PORT" || exit 1

source "${BASH_SOURCE[0]%/*}/_proxy-ensure.sh"
proxy_ensure_model "llamacpp-proxy-ollama" "$MODEL" \
  "${LLAMACPP_PROXY_OLLAMA_LISTEN:-127.0.0.1:8081}" || exit 1

export ANTHROPIC_BASE_URL="http://${LLAMACPP_PROXY_OLLAMA_LISTEN:-127.0.0.1:8081}"
export ANTHROPIC_API_KEY="llamacpp-local"

exec claude --bare --model "$MODEL" ${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}
