#!/usr/bin/env bash
set -euo pipefail

case "${BASH_SOURCE[0]}" in
  */*) LAUNCHER_SCRIPT_DIR="${BASH_SOURCE[0]%/*}" ;;
  *) LAUNCHER_SCRIPT_DIR="." ;;
esac
LAUNCHER_SCRIPT_DIR="$(cd -- "$LAUNCHER_SCRIPT_DIR" && pwd -P)" || exit 1

# Wrapper for aider to use ollama.
# aider has native ollama support via the ollama_chat/ model prefix.
#
# Usage: launch-aider --model <model> [aider args...]
#   e.g. launch-aider --model qwen2.5
#        launch-aider --model qwen2.5 --auto-commits

MODEL=""
AIDER_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model|-m)
      if [[ $# -lt 2 || -z "${2:-}" || "${2:-}" == -* ]]; then
        echo "Error: $1 requires a model value" >&2
        exit 2
      fi
      MODEL="$2"
      shift 2
      ;;
    --model=*)
      MODEL="${1#--model=}"
      if [[ -z "$MODEL" ]]; then
        echo "Error: --model requires a non-empty value" >&2
        exit 2
      fi
      shift
      ;;
    *)
      AIDER_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: launch-aider --model <model> [aider args...]" >&2
  exit 1
fi

source "$LAUNCHER_SCRIPT_DIR/_ollama-ensure.sh"
ollama_normalize_base_url
ollama_ensure_model "$MODEL" "$OLLAMA_BASE_URL" || exit 1

export OLLAMA_API_BASE="${OLLAMA_BASE_URL}"

exec aider \
  --model "ollama_chat/${MODEL}" \
  ${AIDER_ARGS[@]+"${AIDER_ARGS[@]}"}
