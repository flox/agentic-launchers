#!/usr/bin/env bash
set -euo pipefail

# Wrapper for hermes-agent to use ollama directly (OpenAI-compat endpoint).
#
# Usage: launch-hermes --model <model> [hermes-agent args...]
#   e.g. launch-hermes --model qwen2.5-coder

MODEL=""
HERMES_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)
      MODEL="${2:?--model requires a value}"
      shift 2
      ;;
    *)
      HERMES_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: launch-hermes --model <model> [hermes-agent args...]" >&2
  exit 1
fi

source "${BASH_SOURCE[0]%/*}/_ollama-ensure.sh"
ollama_normalize_host_port
ollama_ensure_model "$MODEL" "$OLLAMA_HOST" "$OLLAMA_PORT" || exit 1

export OPENAI_BASE_URL="http://${OLLAMA_HOST}:${OLLAMA_PORT}/v1"
export OPENAI_API_KEY="ollama"

exec hermes-agent --model "$MODEL" ${HERMES_ARGS[@]+"${HERMES_ARGS[@]}"}
