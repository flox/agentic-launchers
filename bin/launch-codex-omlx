#!/usr/bin/env bash
set -euo pipefail

case "${BASH_SOURCE[0]}" in
  */*) LAUNCHER_SCRIPT_DIR="${BASH_SOURCE[0]%/*}" ;;
  *) LAUNCHER_SCRIPT_DIR="." ;;
esac
LAUNCHER_SCRIPT_DIR="$(cd -- "$LAUNCHER_SCRIPT_DIR" && pwd -P)" || exit 1

# Wrapper for codex to use omlx directly (OpenAI-compat endpoint).
# Data is isolated to $FLOX_ENV_CACHE/codex via CODEX_HOME so ~/.codex
# is never touched.
#
# Provider/model are injected via -c flags rather than rewriting config.toml,
# so any settings the user has added (MCP servers, project trust, etc.) are
# preserved untouched.
#
# Usage: launch-codex-omlx --model <hf-model-id> [codex args...]
#   e.g. launch-codex-omlx --model mlx-community/Qwen2.5-Coder-1.5B-Instruct-4bit

MODEL=""
CODEX_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model|-m)
      if [[ $# -lt 2 || -z "${2:-}" || "${2:-}" == -* ]]; then
        echo "Error: $1 requires a model value" >&2
        exit 2
      fi
      MODEL="$2"
      shift 2
      ;;
    --model=*)
      MODEL="${1#--model=}"
      if [[ -z "$MODEL" ]]; then
        echo "Error: --model requires a non-empty value" >&2
        exit 2
      fi
      shift
      ;;
    *)
      CODEX_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: omlx launch codex --model <hf-model-id> [codex args...]" >&2
  exit 1
fi

OMLX_HOST="${OMLX_HOST:-127.0.0.1}"
OMLX_PORT="${OMLX_PORT:-8000}"

source "$LAUNCHER_SCRIPT_DIR/_omlx-ensure.sh"
OMLX_BASE_URL="$(_omlx_base_url "$OMLX_HOST" "$OMLX_PORT")" || exit 1
omlx_ensure_model "$MODEL" "$OMLX_HOST" "$OMLX_PORT" || exit 1

export CODEX_HOME="${FLOX_ENV_CACHE}/codex"
mkdir -p "$CODEX_HOME"

# Write auth.json once — codex requires apikey auth mode to be set.
# The OPENAI_API_KEY value is a dummy; the omlx provider uses OMLX_API_KEY
# via env_key and ignores it.
source "$LAUNCHER_SCRIPT_DIR/_launcher-common.sh"
printf '%s' '{"auth_mode":"apikey","OPENAI_API_KEY":"lm-studio"}' \
  | launcher_write_file_if_absent "$CODEX_HOME/auth.json" 600

# OMLX_MODEL_ID is exported by omlx_ensure_model only after the requested
# repository has been proven against the authenticated admin inventory.
exec codex \
  -c 'model_provider="omlx"' \
  -c "model=\"${OMLX_MODEL_ID}\"" \
  -c 'model_providers.omlx.name="oMLX"' \
  -c "model_providers.omlx.base_url=\"${OMLX_BASE_URL}/v1\"" \
  -c 'model_providers.omlx.env_key="OMLX_API_KEY"' \
  ${CODEX_ARGS[@]+"${CODEX_ARGS[@]}"}
