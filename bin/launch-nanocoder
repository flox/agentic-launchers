#!/usr/bin/env bash
set -euo pipefail

case "${BASH_SOURCE[0]}" in
  */*) LAUNCHER_SCRIPT_DIR="${BASH_SOURCE[0]%/*}" ;;
  *) LAUNCHER_SCRIPT_DIR="." ;;
esac
LAUNCHER_SCRIPT_DIR="$(cd -- "$LAUNCHER_SCRIPT_DIR" && pwd -P)" || exit 1

# Wrapper for nanocoder to use ollama via the OpenAI-compatible API.
# Provider config is injected via NANOCODER_PROVIDERS (highest priority over
# project and global configs). Config is isolated to $FLOX_ENV_CACHE/nanocoder
# via NANOCODER_CONFIG_DIR to avoid touching the user's global nanocoder config.
#
# Usage: ollama launch nanocoder --model <model> [nanocoder args...]
#   e.g. ollama launch nanocoder --model qwen2.5-coder:latest

MODEL=""
NANOCODER_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model|-m)
      if [[ $# -lt 2 || -z "${2:-}" || "${2:-}" == -* ]]; then
        echo "Error: $1 requires a model value" >&2
        exit 2
      fi
      MODEL="$2"
      shift 2
      ;;
    --model=*)
      MODEL="${1#--model=}"
      if [[ -z "$MODEL" ]]; then
        echo "Error: --model requires a non-empty value" >&2
        exit 2
      fi
      shift
      ;;
    *)
      NANOCODER_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: ollama launch nanocoder --model <model> [nanocoder args...]" >&2
  exit 1
fi

source "$LAUNCHER_SCRIPT_DIR/_ollama-ensure.sh"
ollama_normalize_base_url
ollama_ensure_model "$MODEL" "$OLLAMA_BASE_URL" || exit 1

NANOCODER_CONFIG_DIR="${FLOX_ENV_CACHE}/nanocoder"
mkdir -p "$NANOCODER_CONFIG_DIR"

# Build provider config JSON via jq — handles all escaping automatically.
# NANOCODER_PROVIDERS takes highest priority over project and global configs.
NANOCODER_PROVIDERS="$(jq -cn \
  --arg baseUrl "${OLLAMA_BASE_URL}/v1" \
  --arg apiKey  "ollama" \
  --arg model   "$MODEL" \
  '[{"name":"ollama","baseUrl":$baseUrl,"apiKey":$apiKey,"models":[$model],"sdkProvider":"openai-compatible"}]')"

export NANOCODER_CONFIG_DIR NANOCODER_PROVIDERS

exec nanocoder --provider ollama --model "$MODEL" ${NANOCODER_ARGS[@]+"${NANOCODER_ARGS[@]}"}
